# Aurora local config — template. Copy to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your machine-specific paths

# Absolute path to your local clone of the homebrew-aurora tap repo.
# Used by scripts/bump-tap.sh to know where to push the empty bump commit.
# Example: TAP_REPO=/Users/you/dev/homebrew-aurora
TAP_REPO=
