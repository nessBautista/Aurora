# Aurora local config — template. Copy to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your machine-specific paths

# Absolute path to your local clone of the homebrew-aurora tap repo.
# Used by scripts/bump-tap.sh to know where to push the empty bump commit.
# Example: TAP_REPO=/Users/you/dev/homebrew-aurora
TAP_REPO=

# ── LLM provider credentials (optional) ───────────────────────────────
# Aurora resolves each provider's API key in this order:
#   {PROVIDER}_API_KEY env var
#     → macOS keychain (via `aurora auth set <provider>`)
#       → this .env file
# Recommended path is the keychain: `aurora auth set anthropic` /
# `aurora auth set openrouter` (Touch ID protected). Set the vars below only
# for CI / scripting where the keychain isn't available.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# ── Selecting a provider ──────────────────────────────────────────────
# `aurora chat` has NO default provider — you must select one (no silent
# fallback). Resolution order: --provider flag → LLM_PROVIDER → stored choice.
#   aurora auth use <provider>          # persist a default (anthropic | openrouter)
#   aurora chat --provider <provider>   # per-call override
#   LLM_PROVIDER=<provider>             # env override (uncomment below)
#
# LLM_PROVIDER=
